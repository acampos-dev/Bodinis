@model ProductoFormViewModel

@{
    var opciones = ViewData["Categorias"] as IReadOnlyList<CategoriaOptionViewModel> ?? Array.Empty<CategoriaOptionViewModel>();
    var suffix = Model.Id > 0 ? Model.Id.ToString() : "Nuevo";
    var nombreId = $"NombreProducto{suffix}";
    var precioId = $"Precio{suffix}";
    var stockId = $"Stock{suffix}";
    var categoriaId = $"CategoriaId{suffix}";
    var disponibleId = $"Disponible{suffix}";
}

<div class="admin-form-grid">
    <div class="admin-form-field full">
        <label for="@nombreId">Nombre</label>
        <input id="@nombreId" name="NombreProducto" type="text" value="@Model.NombreProducto" required />
    </div>

    <div class="admin-form-field">
        <label for="@precioId">Precio</label>
        <span class="money-input-shell">
            <span aria-hidden="true">$</span>
            <input id="@precioId" name="Precio" type="text" inputmode="numeric" data-money-input value="@Model.Precio" required />
        </span>
    </div>

    <div class="admin-form-field">
        <label for="@stockId">Stock</label>
        <input id="@stockId" name="Stock" type="number" min="0" value="@Model.Stock" required />
    </div>

    <div class="admin-form-field full">
        <label for="@categoriaId">Categoria</label>
        <select id="@categoriaId" name="CategoriaId" required>
            <option value="">Seleccionar categoria</option>
            @foreach (var categoria in opciones)
            {
                if (categoria.Id == Model.CategoriaId)
                {
                    <option value="@categoria.Id" selected>@categoria.Nombre</option>
                }
                else
                {
                    <option value="@categoria.Id">@categoria.Nombre</option>
                }
            }
        </select>
    </div>

    <label class="admin-form-check full">
        <input type="hidden" name="Disponible" value="false" />
        <input id="@disponibleId" type="checkbox" name="Disponible" value="true" checked="@Model.Disponible" />
        Disponible para la venta
    </label>
</div>
