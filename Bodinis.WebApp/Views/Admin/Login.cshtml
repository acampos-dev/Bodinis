@model AdminLoginViewModel

@{
    ViewData["Title"] = "Login administrador";
    ViewData["BodyClass"] = "admin-login-page";
    ViewData["HideChrome"] = true;
}

<section class="admin-login-shell" aria-labelledby="login-title">
    <div class="login-brand-panel">
        <img class="login-logo" src="~/img/bodinis-logo.png" alt="Bodinis" />
        <div class="login-brand-copy">
            <p class="login-kicker">Panel administrador</p>
            <h1 id="login-title">Entrá al control diario de Bodinis</h1>
            <p>Ventas del día, caja, pedidos y productos listos para gestionarse desde un solo lugar.</p>
        </div>
        <div class="login-preview">
            <div>
                <span>Ventas de hoy</span>
                <strong>$ 24.850</strong>
            </div>
            <div>
                <span>Pedidos activos</span>
                <strong>18</strong>
            </div>
            <div>
                <span>Caja</span>
                <strong>Abierta</strong>
            </div>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-card">
            <div class="login-card-header">
                <p class="login-kicker">Bienvenido</p>
                <h2>Iniciar sesión</h2>
            </div>

            @if (TempData["LoginInfo"] is string loginInfo)
            {
                <div class="alert alert-warning login-alert" role="alert">
                    @loginInfo
                </div>
            }

            <form asp-action="Login" asp-controller="Admin" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-floating login-field">
                    <input asp-for="Email" class="form-control" autocomplete="username" placeholder="admin@bodinis.com" />
                    <label asp-for="Email"></label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-floating login-field">
                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Contraseña" />
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="login-options">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <a href="#" aria-label="Recuperar contraseña">Olvidé mi contraseña</a>
                </div>

                <button class="btn login-submit" type="submit">Ingresar al panel</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
